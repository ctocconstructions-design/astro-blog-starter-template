---
const navItems = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Services", href: "/services" },
  { name: "Projects", href: "/projects" },
  { name: "Testimonials", href: "/testimonials" },
  { name: "Contact", href: "/contact" },
];
---

<header class="header">

  <div class="container">

    <a href="/" class="logo">

      <img src="/images/logo.png" alt="C2C Logo" />

      <span>C2C</span>

    </a>

    <nav class="desktop-nav">

      {navItems.map(item => (

        <a href={item.href}>{item.name}</a>

      ))}

    </nav>

    <a href="tel:+918080004559" class="call-btn">

      Call Now

    </a>

    <button class="menu-btn" id="menuButton">

      ☰

    </button>

  </div>

  <div class="mobile-menu" id="mobileMenu">

    {navItems.map(item => (

      <a href={item.href}>{item.name}</a>

    ))}

    <a href="tel:+918080004559" class="mobile-call">

      📞 Call Now

    </a>

  </div>

</header>

<style>

.header{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  z-index:1000;
  transition:.35s;
  background:rgba(10,10,10,.55);
  backdrop-filter:blur(12px);
}

.container{
  max-width:1400px;
  margin:auto;
  padding:18px 40px;
  display:flex;
  align-items:center;
  justify-content:space-between;
}

.logo{
  display:flex;
  align-items:center;
  gap:14px;
  color:#fff;
  text-decoration:none;
  font-size:32px;
  font-weight:800;
}

.logo img{
  width:60px;
  height:60px;
  object-fit:contain;
}

.desktop-nav{
  display:flex;
  gap:38px;
}

.desktop-nav a{
  color:#fff;
  text-decoration:none;
  font-size:17px;
  font-weight:500;
  transition:.3s;
  position:relative;
}

.desktop-nav a:hover{
  color:#ffffff;
}

.desktop-nav a::after{
  content:"";
  position:absolute;
  left:0;
  bottom:-8px;
  width:0;
  height:2px;
  background:#ffffff;
  transition:.3s;
}

.desktop-nav a:hover::after{
  width:100%;
}

.call-btn{
  padding:14px 26px;
  border-radius:8px;
  background:#fff;
  color:#111;
  text-decoration:none;
  font-weight:700;
  transition:.3s;
}

.call-btn:hover{
  background:#d9d9d9;
}

.menu-btn{
  display:none;
  background:none;
  border:none;
  color:#fff;
  font-size:34px;
  cursor:pointer;
}

.mobile-menu{
  display:none;
}

/* ---------------- MOBILE ---------------- */

@media (max-width:900px){

.container{
  padding:16px 20px;
}

.logo span{
  font-size:28px;
}

.logo img{
  width:48px;
  height:48px;
}

.desktop-nav{
  display:none;
}

.call-btn{
  display:none;
}

.menu-btn{
  display:block;
}

.mobile-menu{
  display:flex;
  flex-direction:column;
  position:absolute;
  top:82px;
  left:0;
  width:100%;
  background:#111;
  max-height:0;
  overflow:hidden;
  transition:max-height .4s ease;
}

.mobile-menu.active{
  max-height:500px;
}

.mobile-menu a{
  color:#fff;
  text-decoration:none;
  padding:18px 25px;
  border-bottom:1px solid rgba(255,255,255,.08);
  font-size:18px;
}

.mobile-menu a:hover{
  background:#222;
}

.mobile-call{
  background:#fff;
  color:#111 !important;
  font-weight:700;
}

}

</style>

<script>

const menuButton = document.getElementById("menuButton");
const mobileMenu = document.getElementById("mobileMenu");

if (menuButton && mobileMenu) {

  menuButton.addEventListener("click", () => {

    mobileMenu.classList.toggle("active");

    if (mobileMenu.classList.contains("active")) {
      menuButton.innerHTML = "✕";
    } else {
      menuButton.innerHTML = "☰";
    }

  });

}

// Close menu when a link is clicked
document.querySelectorAll("#mobileMenu a").forEach(link => {

  link.addEventListener("click", () => {

    mobileMenu.classList.remove("active");

    menuButton.innerHTML = "☰";

  });

});

</script>
