---

<section class="hero">

  <div class="overlay"></div>

  <div class="hero-container">

    <p class="top-text">
      RESIDENTIAL • COMMERCIAL • INDUSTRIAL
    </p>

    <div class="brand">

      <img
        src="/images/logo.png"
        alt="C2C Logo"
        class="logo"
      />

      <div class="brand-text">

        <h1>C2C</h1>

        <h2>CONSTRUCTIONS</h2>

      </div>

    </div>

    <div class="headline">

      <h3>
        WE EXECUTE
      </h3>

      <h4>
        YOUR DREAMS.
      </h4>

    </div>

    <div class="highlights">

      <div class="item">

        <div class="icon">👷</div>

        <span>
          Former L&T Engineers
        </span>

      </div>

      <div class="item">

        <div class="icon">🏆</div>

        <span>
          15+ Years Experience
        </span>

      </div>

      <div class="item">

        <div class="icon">🏗️</div>

        <span>
          Quality Workmanship
        </span>

      </div>

    </div>

    <div class="buttons">

      <a
        href="tel:+918080004559"
        class="primary-btn"
      >
        📞 Call Now
      </a>

      <a
        href="#projects"
        class="secondary-btn"
      >
        View Projects →
      </a>

    </div>

  </div>

  <div class="scroll">

      <span></span>

  </div>

</section>

<style>

@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700&display=swap');

*{
margin:0;
padding:0;
box-sizing:border-box;
}

.hero{

position:relative;

height:100vh;

display:flex;

align-items:center;

overflow:hidden;

background:url("/images/hero-banner.png") center center/cover no-repeat;

font-family:'Poppins',sans-serif;

}

.overlay{

position:absolute;

inset:0;

background:linear-gradient(
90deg,
rgba(15,18,22,.82) 0%,
rgba(15,18,22,.68) 35%,
rgba(15,18,22,.28) 65%,
rgba(15,18,22,.05) 100%
);

}

.hero-container{

position:relative;

z-index:5;

width:700px;

margin-left:90px;

animation:fadeUp 1s ease;

}

.top-text{

font-size:20px;

letter-spacing:5px;

font-weight:500;

color:#ffffff;

margin-bottom:30px;

text-transform:uppercase;

opacity:.95;

}

.brand{

display:flex;

align-items:center;

gap:30px;

margin-bottom:35px;

}

.logo{

width:330px;

height:auto;

filter:drop-shadow(0 15px 35px rgba(255,255,255,.20));

}

.brand-text h1{

font-family:'Montserrat',sans-serif;

font-size:100px;

font-weight:800;

line-height:100px;

color:#ffffff;

text-shadow:0 5px 25px rgba(0,0,0,.55);

}

.brand-text h2{

font-family:'Montserrat',sans-serif;

font-size:55px;

font-weight:500;

letter-spacing:3px;

color:#f5f5f5;

}

.headline{

margin:25px 0 35px;

}

.headline h3{

font-family:'Montserrat',sans-serif;

font-size:60px;

font-weight:600;

line-height:70px;

color:white;

text-shadow:0 4px 18px rgba(0,0,0,.5);

}

.headline h4{

font-family:'Montserrat',sans-serif;

font-size:55px;

font-weight:500;

letter-spacing:8px;

color:#dddddd;

margin-top:10px;

}
.highlights{

display:flex;

gap:30px;

margin:40px 0;

flex-wrap:wrap;

}

.item{

display:flex;

align-items:center;

gap:15px;

background:rgba(255,255,255,.10);

backdrop-filter:blur(10px);

padding:14px 18px;

border:1px solid rgba(255,255,255,.18);

border-radius:14px;

transition:.35s;

}

.item:hover{

transform:translateY(-6px);

background:rgba(255,255,255,.18);

}

.icon{

width:50px;

height:50px;

display:flex;

align-items:center;

justify-content:center;

font-size:24px;

border-radius:50%;

background:rgba(255,255,255,.18);

}

.item span{

font-size:18px;

font-weight:500;

color:#ffffff;

line-height:28px;

}

.buttons{

display:flex;

gap:20px;

margin-top:45px;

}

.primary-btn{

display:inline-flex;

align-items:center;

justify-content:center;

padding:18px 40px;

background:#ffffff;

color:#111;

font-size:20px;

font-weight:700;

text-decoration:none;

border-radius:10px;

transition:.35s;

box-shadow:0 12px 35px rgba(0,0,0,.25);

}

.primary-btn:hover{

transform:translateY(-5px);

background:#efefef;

}

.secondary-btn{

display:inline-flex;

align-items:center;

justify-content:center;

padding:18px 40px;

border:2px solid rgba(255,255,255,.85);

color:#ffffff;

font-size:20px;

font-weight:600;

text-decoration:none;

border-radius:10px;

transition:.35s;

backdrop-filter:blur(12px);

}

.secondary-btn:hover{

background:#ffffff;

color:#111;

transform:translateY(-5px);

}

.scroll{

position:absolute;

bottom:35px;

left:50%;

transform:translateX(-50%);

z-index:5;

}

.scroll span{

display:block;

width:28px;

height:48px;

border:2px solid rgba(255,255,255,.8);

border-radius:20px;

position:relative;

}

.scroll span::before{

content:"";

position:absolute;

top:8px;

left:50%;

width:6px;

height:6px;

background:#ffffff;

border-radius:50%;

transform:translateX(-50%);

animation:scrollDown 1.6s infinite;

}

@keyframes scrollDown{

0%{

opacity:1;

transform:translate(-50%,0);

}

100%{

opacity:0;

transform:translate(-50%,20px);

}

}

@keyframes fadeUp{

0%{

opacity:0;

transform:translateY(60px);

}

100%{

opacity:1;

transform:translateY(0);

}

}
/* ---------- Responsive ---------- */

@media (max-width:1200px){

.hero-container{
    width:620px;
    margin-left:60px;
}

.logo{
    width:150px;
}

.brand-text h1{
    font-size:90px;
    line-height:78px;
}

.brand-text h2{
    font-size:42px;
}

.headline h3{
    font-size:60px;
    line-height:60px;
}

.headline h4{
    font-size:40px;
}

}

@media (max-width:900px){

.hero{

padding:120px 25px 80px;

height:auto;

min-height:100vh;

align-items:flex-start;

}

.hero-container{

margin:0;

width:100%;

}

.top-text{

font-size:14px;

letter-spacing:3px;

}

.brand{

flex-direction:column;

align-items:flex-start;

gap:20px;

}

.logo{

width:120px;

}

.brand-text h1{

font-size:72px;

line-height:65px;

}

.brand-text h2{

font-size:32px;

}

.headline{

margin:20px 0 30px;

}

.headline h3{

font-size:46px;

line-height:48px;

}

.headline h4{

font-size:30px;

letter-spacing:3px;

}

.highlights{

flex-direction:column;

gap:15px;

}

.item{

width:100%;

}

.item span{

font-size:17px;

}

.buttons{

flex-direction:column;

gap:15px;

}

.primary-btn,

.secondary-btn{

width:100%;

justify-content:center;

font-size:18px;

padding:16px;

}

.scroll{

display:none;

}

}

@media (max-width:480px){

.logo{

width:95px;

}

.brand-text h1{

font-size:52px;

line-height:48px;

}

.brand-text h2{

font-size:24px;

}

.headline h3{

font-size:34px;

line-height:36px;

}

.headline h4{

font-size:22px;

}

.top-text{

font-size:12px;

letter-spacing:2px;

}

.item{

padding:12px;

}

.item span{

font-size:15px;

}

.primary-btn,

.secondary-btn{

font-size:16px;

}

}

</style>
